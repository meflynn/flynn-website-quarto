@misc{machainBidenSendingMore2022,
  title = {Biden Sending More Troops to {{Eastern Europe}} -- 3 Key Issues behind the Decision},
  author = {Machain, Carla Martinez and Allen, Michael A. and Flynn, Michael E.},
  year = 2022,
  journal = {The Conversation},
