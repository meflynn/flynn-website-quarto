@article{AR1997,
  title = {Social Network Effects on the Extent of Innovation Diffusion: {{A}} Computer Simulation},
  author = {Abrahamson, Eric and Rosenkopf, Lori},
  year = 1997,
  month = jun,
  journal = {Organization Science},
  volume = {8},
  number = {3},
  pages = {289--309},
  abstract = {Theories of innovation diffusion no longer focus exclusively on explaining the rate at which innovations diffuse or the sequence in which they are adopted. They also focus on explaining why certain innovations diffuse extensively, becoming de facto standards, whereas others do so partially or not at all. Many of these theories specify a bandwagon process: a positive feedback loop in which increases in the number of adopters create stronger bandwagon pressures, and stronger bandwagon pressures, in turn, cause increases in the number of adopters. Factors affecting if and how many times this feedback loop cycles explain if and how many potential adopters jump on a bandwagon. We argue that one important factor has not yet been incorporated into theories explaining bandwagons' extent: the structure of social networks through which potential adopters of innovations find out information about these innovations which can cause them to adopt these innovations. We advance a theory of how the structure of social networks affects bandwagons' extent. We propose that both the number of network links, as well as small, seemingly insignificant idiosyncracies of their structures, can have very large effects on the extent of an innovation's diffusion among members of a social network.}
}

@article{Arase1994,
  title = {Public-Private Sector Interest Coordination in Japan's {{ODA}}},
  author = {Arase, David},
  year = 1994,
  journal = {Pacific Affairs},
  volume = {67},
  number = {2},
  pages = {171--199},
  abstract = {The policy-making structures that govern Japan's official development assistance \textbraceleft (ODA)\textbraceright{} incorporate the Japanese private sector to a greater degree than is commonly supposed. Apart from explaining the limitations that the Ministry of Foreign Affairs faces in setting substantive policy in \textbraceleft ODA,\textbraceright{} this article indicates how mechanisms of private sector inclusion facilitate public-private sector collaboration, and how these mechanisms are integrated into a system of policy formulation and implementation. The system is rooted in the mid-1950s to early 1960s when expanding Japanese private sector activity in the developing world was a key state objective. Under bureaucratic guidance Japan still operates a system of intimate collaboration between the state and private sector in \textbraceleft ODA.\textbraceright{} The dilemma of the private sector today, however, is that while it now wants to reduce the autonomous power of the bureaucracy, it does not want to lose the benefits of privileged access to \textbraceleft ODA\textbraceright{} resources that the status quo system provides.}
}

@article{ArenaPalmer2009,
  title = {Politics or the {{Economy}}? {{Domestic Correlates}} of {{Dispute Involvement}} in {{Development Democracies}}},
  shorttitle = {Politics or the {{Economy}}?},
  author = {Arena, Philip and Palmer, Glenn},
  year = 2009,
