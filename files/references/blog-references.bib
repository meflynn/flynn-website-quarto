@article{Bell2015,
  title = {The Origins of Party Identification and Its Relationship to Political Orientations},
  author = {Bell, Edward and Kandler, Christian},
  year = 2015,
  month = sep,
  journal = {Personality and Individual Differences},
  volume = {83},
  pages = {136--141},
  issn = {01918869},
  doi = {10.1016/j.paid.2015.04.002},
  abstract = {An established position, long recognized in the literature, maintains that political party identification (PID) arises mainly from familial socialization and has a major impact on political outlooks and behaviors. An alternative view, also entrenched in the literature, holds that the direction of causation may go the other way, with political orientations influencing PID insofar as individuals seek out parties that match their ideological viewpoints. Here we use univariate and multivariate twin modeling to examine the underlying etiology assumed by those two positions, and introduce a new perspective that may help researchers make sense of PID, political orientations, and the relationships between them. Our findings indicate that: (1) PID is substantially heritable; and (2) there is empirical support for a model in which genetic and environmental factors influence political orientations, which in turn affect PID.},
  keywords = {Behaviour genetics,Heritability,Political attitudes,Political orientations,Political party identification,Twin study}
}

@article{Bell2016,
  title = {The Effect of {{US}} Troop Deployments on Human Rights},
  author = {Bell, S. R. and Clay, K. C. and Martinez Machain, C.},
  year = 2016,
  month = apr,
  journal = {Journal of Conflict Resolution},
  pages = {0022002716632300--},
  issn = {0022-0027},
  doi = {10.1177/0022002716632300},
  abstract = {US noninvasion troops deployed abroad often try to promote greater respect for human rights in the host country. The host country, having an incentive to retain the troop presence, may choose to comply with these requests. We argue that this effect will not be at play in states with high security salience for the United States (US) (for which the US may not be able to credibly threaten to remove the troops). In these cases, US deployments will provide the leader with security from both internal and external threats that is independent of the local populations support for the leader. Host state leaders thus become less reliant on (and potentially less responsive to) their local populations, which in turn may lead to increased human rights violations. In this article, we use data on both US troop deployments abroad and on human rights violations to test these arguments from 1982 to 2005.},
  mendeley-tags = {Human Rights,Troops},
  keywords = {Human Rights,Troops}
}

