@article{bansakNumberChoiceTasks2018,
  title = {The {{Number}} of {{Choice Tasks}} and {{Survey Satisficing}} in {{Conjoint Experiments}}},
  author = {Bansak, Kirk and Hainmueller, Jens and Hopkins, Daniel J. and Yamamoto, Teppei},
  year = 2018,
