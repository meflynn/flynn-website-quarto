@article{blankenshipPurchasingPowerUS2020,
  title = {Purchasing {{Power}}: {{US Overseas Defense Spending}} and {{Military Statecraft}}},
  shorttitle = {Purchasing {{Power}}},
  author = {Blankenship, Brian and Miles Joyce, Renanah},
  year = 2020,
