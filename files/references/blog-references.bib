@article{Fajardo-Heyward2015,
  title = {Understanding the {{Effect}} of {{Security Assistance}} on {{Human Rights}}: {{The Case}} of {{Plan Colombia}}},
  shorttitle = {Understanding the {{Effect}} of {{Security Assistance}} on {{Human Rights}}},
  author = {{Fajardo-Heyward}, Paola},
  year = 2015,
  journal = {The Latin Americanist},
  volume = {59},
  number = {2},
  pages = {3--27},
  issn = {1557-203X},
  doi = {10.1111/tla.12052},
  urldate = {2023-08-03},
  abstract = {Existing large-N research argues that governments that rely on their citizens for their revenue are more accountable to their citizens and thus have more incentives to protect human rights. This argument predicts that other sources of revenue fail to provide such incentives. Due to this, governments that rely on alternative sources of revenue will experience poor human rights conditions. This article is aimed at exploring this expectation by looking at one particular type of alternative source of revenue: security assistance. According to the argument, security assistance should negatively impact human rights conditions due to its effect on governments' efforts to protect and respect human rights. This article uses the case of Plan Colombia to assess this argument. By looking at the way in which foreign assistance interacts with domestic institutions, the case suggest that the negative effect is caused by the erosion on checks and balances and, most importantly, by changes in civil-military relations.},
  langid = {english},
  keywords = {Foreign Aid,Human Rights},
  file = {/Users/michaelflynn/Zotero/storage/4UJLPP57/Fajardo-Heyward - 2015 - Understanding the Effect of Security Assistance on.pdf;/Users/michaelflynn/Zotero/storage/RBVZSZ77/tla.html}
}

@article{FangJohnsonLeeds2014,
  title = {To Concede or to Resist? {{The}} Restraining Effect of Military Alliances},
  author = {Fang, Songying and Johnson, Jesse C. and Leeds, Brett Ashley},
  year = 2014,
  month = aug,
  journal = {International Organization},
  volume = {68},
  number = {4},
  pages = {775--809},
  publisher = {Cambridge University Press},
  issn = {15315088},
  doi = {10.1017/S0020818314000137},
  abstract = {Creating institutions that effectively manage interstate conflict is a priority for policy-makers. In this article we demonstrate that military allies are well positioned to influence the crisis-bargaining behavior of both challengers and targets in ways that often lead to peace. Through a three-player game-theoretic model, we demonstrate that a target's alliances not only have an effect on the demand that the challenger makes, but also on the behavior of the target. When a target values an alliance highly, an ally's recommendation for settlement can encourage the target to concede to demands without further escalation. Our statistical analysis provides evidence in support of the theoretical finding. Allies can both deter challengers and restrain partners, and as a result, can encourage peaceful behavior not only from adversaries, but from member states as well. Our study thus sheds new light on the role of military alliances as potential conflict management devices.}
}

