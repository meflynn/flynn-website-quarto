@article{Schultz1998,
  title = {Domestic Opposition and Signaling in International Crises},
  author = {Schultz, Kenneth A.},
  year = 1998,
  month = dec,
  journal = {American Political Science Review},
  volume = {92},
  number = {04},
  pages = {829--844},
  publisher = {American Political Science Association},
  issn = {0003-0554},
  doi = {10.2307/2586306},
  abstract = {This article explores the effect of domestic political competition on the escalation of international crises. It combines an incomplete information model of crisis bargaining with a simple model of two-party electoral choice. One state has two strategic actors---a government and an opposition party---both of which declare openly whether they support the use of force to alter the status quo. The rival state updates its beliefs and selects its strategy in response to both signals. The parties' payoffs depend upon a retrospective evaluation by the domestic electorate. The model shows that the inclusion of a strategic opposition party decreases the ex ante probability of war by helping to reveal information about the state's preferences. This finding has important implications for research on democracy and international conflict, since it suggests a mechanism through which democratic states can overcome informational asymmetries, which have been identified as a central obstacle to negotiation.},
  keywords = {Democracy,Electorate,Government,Government crises,Opposition parties,Political parties,Politicians,Voting,War}
}

