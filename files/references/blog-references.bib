@article{DeReeNillesen2009,
  title = {Aiding Violence or Peace? {{The}} Impact of Foreign Aid on the Risk of Civil Conflict in Sub-{{Saharan Africa}}},
  author = {{de Ree}, Joppe and Nillesen, Eleonora},
  year = 2009,
  month = mar,
  journal = {Journal of Development Economics},
  volume = {88},
  number = {2},
  pages = {301--313},
  issn = {03043878},
  doi = {10.1016/j.jdeveco.2008.03.005},
  abstract = {This paper considers the impact of foreign aid flows on the risk of civil conflict. We improve on earlier studies on this topic by addressing the problem of the endogenous aid allocation using GDP levels of donor countries as instruments. A more structural addition to the literature is that we efficiently control for unobserved country specific effects in typical conflict onset and conflict continuation models by first differencing. The literature often overlooks the dynamic nature of these types of models, thereby forcing unlikely i.i.d. structures on the error terms implicitly.11i.e., i.i.d. error structures in linear models, or conditional independence of observations in non-linear probit/logit type models. As a consequence, malfunctioning institutions, deep-rooted political grievances, or any other obvious, yet unobserved and time persistent determinants of war are simply assumed away. We find a statistically significant and economically important negative effect of foreign aid flows on the probability of ongoing civil conflicts to continue (the continuation probability), such that increasing aid flows tends to decrease civil conflict duration. We do not find a significant relationship between aid flows and the probability of civil conflicts to start (the onset probability).},
  mendeley-tags = {Conflict,Foreign Aid},
  keywords = {Civil conflict,Conflict,D74,F35,Foreign aid,Foreign Aid,H56,O55,Sub-Saharan Africa}
}

@article{DerouenJr2004,
