@article{Passmoreetal2018,
  title = {Rallying the Troops: {{Collective}} Action and Self-Interest in {{UN}} Peacekeeping Contributions},
  author = {Passmore, Timothy JA and Shannon, Megan and Hart, Andrew F},
  year = 2018,
  month = may,
  journal = {Journal of Peace Research},
  volume = {55},
