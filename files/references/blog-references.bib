@article{Allenetal2025,
  title = {At the Edge of War: {{Frontline}} Ally Support for the {{United States}} Military1},
  shorttitle = {At the Edge of War},
  author = {Allen, Michael and Flynn, Michael and Mart{\'i}nez Machain, Carla and Smu{\l}ek, Grzegorz},
  year = 2025,
