  number = {1},
  pages = {29--45},
  publisher = {University of Toronto Press},
  abstract = {This analysis of public opinion toward foreign aid shows that Canadians are divided over internationalism, on two counts. First, while most citizens agree that development assistance is important, their support often remains shallow, unmatched by a commitment to undertake concrete actions. Second, the attitudes that Canadians hold toward development assistance indicate that there is a division in the country's public between liberal and conservative internationalists, a cleavage that is anchored in domestic ideological and partisan differences. Comparable to what is found in other countries, the internationalism of Canadians does not appear as vigorous and as consensual as is often suggested.},
